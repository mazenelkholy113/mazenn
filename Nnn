      <div style={{ display:"flex", flexDirection:"column", gap:12 }}>
        {files.map(f => (
          <div key={f.id} style={{
            display:"flex", alignItems:"center", justifyContent:"space-between",
            background:"rgba(255,255,255,0.04)", border:"1px solid rgba(201,168,76,0.2)",
            borderRadius:10, padding:"14px 18px", flexWrap:"wrap", gap:10
          }}>
            <div>
              <div style={{ fontWeight:600, color:"#e8d5b7" }}>📄 {f.name}</div>
              <div style={{ fontSize:12, color:"#999", marginTop:4 }}>{f.date} | {f.size}</div>
