// ==================== GRADES MODULE ====================
function GradesModule({ students, grade, onBack }) {
  const [grades, setGrades] = useState({});
  const [notify, setNotify] = useState(null);
  const exams = ["امتحان 1", "امتحان 2", "امتحان 3", "أعمال سنة"];
  const maxMarks = { "امتحان 1": 25, "امتحان 2": 25, "امتحان 3": 30, "أعمال سنة": 20 };

  const setMark = (sid, exam, val) => {
    const max = maxMarks[exam];
    const v = Math.min(max, Math.max(0, Number(val)));
    setGrades(g => ({ ...g, [sid]: { ...(g[sid] || {}), [exam]: v } }));
  };

  const total = (sid) => exams.reduce((s, e) => s + (grades[sid]?.[e] || 0), 0);
  const maxTotal = Object.values(maxMarks).reduce((a, b) => a + b, 0);

  const getRating = (t) => {
    const pct = (t / maxTotal) * 100;
    if (pct >= 90) return { label: "ممتاز", color: "#27ae60", emoji: "🏆" };
    if (pct >= 75) return { label: "جيد جداً", color: "#3498db", emoji: "⭐" };
    if (pct >= 65) return { label: "جيد", color: "#9b59b6", emoji: "✅" };
    if (pct >= 50) return { label: "مقبول", color: "#f39c12", emoji: "📝" };
    return { label: "ضعيف", color: "#e74c3c", emoji: "⚠" };
  };

  const ranked = [...students].sort((a, b) => total(b.id) - total(a.id));

  const sendGrade = (s) => {
    const t = total(s.id);
    const r = getRating(t);
    setNotify(`تم إرسال درجة ${s.name} (${t}/${maxTotal} - ${r.label}) لولي الأمر`);
  };

  return (
    <div style={moduleWrap}>
      {notify && <NotificationToast msg={notify} onClose={() => setNotify(null)} />}
      <div style={moduleHeader}>
        <button onClick={onBack} style={backBtn}>← رجوع</button>
        <h2 style={moduleTitle}>📊 الدرجات — {gradeNames[grade]}</h2>
      </div>

      <div style={{ overflowX:"auto" }}>
        <table style={tableStyle}>
          <thead>
            <tr>
              <th style={th}>الترتيب</th>
              <th style={th}>الطالب</th>
              {exams.map(e => <th key={e} style={th}>{e}<br/><span style={{ fontSize:10, color:"#aaa" }}>/{maxMarks[e]}</span></th>)}
              <th style={th}>الإجمالي</th>
              <th style={th}>التقدير</th>
              <th style={th}>إرسال</th>
            </tr>
          </thead>
          <tbody>
            {ranked.map((s, i) => {
              const t = total(s.id);
              const r = getRating(t);
              return (
                <tr key={s.id} style={{ background: i === 0 ? "rgba(201,168,76,0.08)" : "transparent" }}>
                  <td style={{ ...td, fontWeight:"bold", color: i === 0 ? "#c9a84c" : "#ddd" }}>
                    {i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : i+1}
                  </td>
                  <td style={{ ...td, fontWeight:600 }}>{s.name}</td>
                  {exams.map(e => (
                    <td key={e} style={td}>
                      <input type="number" min="0" max={maxMarks[e]}
                        value={grades[s.id]?.[e] || ""}
                        onChange={ev => setMark(s.id, e, ev.target.value)}
                        style={{ ...inputStyle, width:60, textAlign:"center", padding:"4px" }} />
                    </td>
                  ))}
                  <td style={{ ...td, fontWeight:"bold", color: r.color }}>
                    {t}/{maxTotal}
                  </td>
                  <td style={{ ...td, color: r.color }}>{r.emoji} {r.label}</td>
                  <td style={td}>
                    <button onClick={() => sendGrade(s)} style={{ ...addBtn, padding:"6px 10px", fontSize:11 }}>
                      📤
                    </button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ==================== STATS MODULE ====================
function StatsModule({ students, grade, onBack }) {
  const month = monthNames[new Date().getMonth()];

  const mockData = students.map((s, i) => ({
    ...s,
    absences: Math.floor(Math.random() * 5),
    paid: i % 3 !== 0,
    gradeTotal: Math.floor(Math.random() * 40) + 60,
    examDone: i % 4 !== 0,
  }));

  const getRating = (t) => {
    if (t >= 90) return { label: "ممتاز", color: "#27ae60" };
    if (t >= 75) return { label: "جيد جداً", color: "#3498db" };
    if (t >= 65) return { label: "جيد", color: "#9b59b6" };
    if (t >= 50) return { label: "مقبول", color: "#f39c12" };
    return { label: "ضعيف", color: "#e74c3c" };
  };

  const mostAbsent = [...mockData].sort((a, b) => b.absences - a.absences)[0];
  const unpaid = mockData.filter(s => !s.paid);
  const noExam = mockData.filter(s => !s.examDone);
  const weakStudents = mockData.filter(s => s.gradeTotal < 65);

  return (
    <div style={moduleWrap}>
      <div style={moduleHeader}>
        <button onClick={onBack} style={backBtn}>← رجوع</button>
        <h2 style={moduleTitle}>📈 إحصائيات شهر {month} — {gradeNames[grade]}</h2>
      </div>

      <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit, minmax(220px, 1fr))", gap:16, marginBottom:24 }}>
        <StatCard emoji="❌" label="أكثر طالب غياباً" value={mostAbsent?.name} sub={`${mostAbsent?.absences} حصص`} color="#e74c3c" />
        <StatCard emoji="💰" label="لم يدفعوا" value={`${unpaid.length} طلاب`} sub={unpaid.map(s => s.name).join(", ")} color="#f39c12" />
        <StatCard emoji="📝" label="لم يمتحنوا" value={`${noExam.length} طلاب`} sub={noExam.map(s => s.name).join(", ")} color="#9b59b6" />
        <StatCard emoji="⚠" label="درجات ضعيفة" value={`${weakStudents.length} طلاب`} sub={weakStudents.map(s => s.name).join(", ")} color="#e74c3c" />
      </div>

      <h3 style={{ color:"#c9a84c", marginBottom:12 }}>📊 تفصيلي الطلاب</h3>
      <div style={tableWrap}>
        <table style={tableStyle}>
          <thead>
            <tr>
              <th style={th}>الطالب</th>
              <th style={th}>الغياب</th>
              <th style={th}>المصاريف</th>
              <th style={th}>الامتحان</th>
              <th style={th}>الدرجة</th>
              <th style={th}>التقدير الشهري</th>
            </tr>
          </thead>
          <tbody>
            {mockData.map(s => {
              const r = getRating(s.gradeTotal);
              return (
                <tr key={s.id}>
                  <td style={{ ...td, fontWeight:600 }}>{s.name}</td>
                  <td style={{ ...td, color: s.absences > 3 ? "#e74c3c" : "#ddd" }}>
                    {s.absences} حصص {s.absences > 3 ? "⚠" : ""}
                  </td>
                  <td style={{ ...td, color: s.paid ? "#27ae60" : "#e74c3c" }}>
                    {s.paid ? "✅ دفع" : "❌ لم يدفع"}
                  </td>
                  <td style={{ ...td, color: s.examDone ? "#27ae60" : "#e74c3c" }}>
                    {s.examDone ? "✅ امتحن" : "❌ لم يمتحن"}
                  </td>
                  <td style={{ ...td, fontWeight:"bold", color: r.color }}>
                    {s.gradeTotal}/100
                  </td>
                  <td style={{ ...td, color: r.color, fontWeight:600 }}>
                    {r.label}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

function StatCard({ emoji, label, value, sub, color }) {
  return (
    <div style={{
      background:`rgba(${color === "#e74c3c" ? "231,76,60" : color === "#f39c12" ? "243,156,18" : color === "#9b59b6" ? "155,89,182" : "39,174,96"},0.1)`,
      border:`1px solid ${color}44`,
      borderRadius:12, padding:16
    }}>
      <div style={{ fontSize:28 }}>{emoji}</div>
      <div style={{ color:"#aaa", fontSize:12, marginTop:4 }}>{label}</div>
      <div style={{ color, fontWeight:"bold", fontSize:18, marginTop:4 }}>{value}</div>
      {sub && <div style={{ color:"#888", fontSize:11, marginTop:4 }}>{sub}</div>}
    </div>
  );
}

// ==================== GRADE DASHBOARD ====================
function GradeDashboard({ grade, students, onBack }) {
  const [activeModule, setActiveModule] = useState(null);

  const modules = [
    { id:"attendance", icon:"📋", label:"تسجيل الغياب", color:"#e74c3c", desc:"حضور وغياب الطلاب" },
    { id:"fees", icon:"💰", label:"المصاريف", color:"#f39c12", desc:"متابعة الدفع الشهري" },
    { id:"files", icon:"📁", label:"ملفات الحصص", color:"#3498db", desc:"رفع وإرسال المحتوى" },
    { id:"messages", icon:"💬", label:"رسائل المجموعة", color:"#9b59b6", desc:"إشعارات للطلاب" },
    { id:"parents", icon:"👨‍👩‍👧", label:"أولياء الأمور", color:"#1abc9c", desc:"أرقام وأسماء" },
    { id:"grades", icon:"📊", label:"الدرجات", color:"#27ae60", desc:"درجات الامتحانات" },
    { id:"stats", icon:"📈", label:"إحصائيات الشهر", color:"#c9a84c", desc:"تقرير شامل" },
  ];

  if (activeModule === "attendance") return <AttendanceModule students={students} grade={grade} onBack={() => setActiveModule(null)} />;
  if (activeModule === "fees") return <FeesModule students={students} grade={grade} onBack={() => setActiveModule(null)} />;
  if (activeModule === "files") return <FilesModule grade={grade} onBack={() => setActiveModule(null)} />;
  if (activeModule === "messages") return <MessagesModule students={students} grade={grade} onBack={() => setActiveModule(null)} />;
  if (activeModule === "parents") return <ParentsModule students={students} grade={grade} onBack={() => setActiveModule(null)} />;
  if (activeModule === "grades") return <GradesModule students={students} grade={grade} onBack={() => setActiveModule(null)} />;
  if (activeModule === "stats") return <StatsModule students={students} grade={grade} onBack={() => setActiveModule(null)} />;

  return (
    <div style={{ padding:24, maxWidth:800, margin:"0 auto" }}>
      <div style={{ display:"flex", alignItems:"center", gap:16, marginBottom:32 }}>
        <button onClick={onBack} style={backBtn}>← رجوع</button>
        <div>
          <h2 style={{ color:"#c9a84c", margin:0, fontSize:22 }}>{gradeNames[grade]}</h2>
          <div style={{ color:"#999", fontSize:13 }}>{students.length} طالب مسجل</div>
        </div>
      </div>

      <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill, minmax(200px, 1fr))", gap:16 }}>
        {modules.map(m => (
          <button key={m.id} onClick={() => setActiveModule(m.id)} style={{
            background:`linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01))`,
            border:`1px solid ${m.color}44`,
            borderRadius:16, padding:"24px 16px", cursor:"pointer", textAlign:"center",
            transition:"all 0.25s", color:"white", fontFamily:"Tajawal, sans-serif",
          }}
          onMouseEnter={e => {
            e.currentTarget.style.transform = "translateY(-4px)";
            e.currentTarget.style.background = `linear-gradient(135deg, ${m.color}22, ${m.color}11)`;
            e.currentTarget.style.borderColor = m.color;
            e.currentTarget.style.boxShadow = `0 8px 24px ${m.color}33`;
          }}
          onMouseLeave={e => {
            e.currentTarget.style.transform = "translateY(0)";
            e.currentTarget.style.background = "linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01))";
            e.currentTarget.style.borderColor = `${m.color}44`;
            e.currentTarget.style.boxShadow = "none";
          }}>
            <div style={{ fontSize:40, marginBottom:10 }}>{m.icon}</div>
            <div style={{ fontWeight:700, fontSize:15, color:"#e8d5b7", marginBottom:4 }}>{m.label}</div>
            <div style={{ fontSize:12, color:"#888" }}>{m.desc}</div>
          </button>
        ))}
      </div>
    </div>
  );
}

