// ==================== NOTIFICATION ====================
function NotificationToast({ msg, onClose }) {
  useEffect(() => { const t = setTimeout(onClose, 3500); return () => clearTimeout(t); }, []);
  return (
    <div style={{
      position:"fixed", top:20, right:20, background:"#1a1a2e", color:"#e8d5b7",
      border:"1px solid #c9a84c", borderRadius:12, padding:"14px 20px",
      boxShadow:"0 8px 32px rgba(0,0,0,0.4)", zIndex:9999, maxWidth:320,
      animation:"slideIn 0.3s ease", direction:"rtl", fontSize:14, fontFamily:"Tajawal, sans-serif"
    }}>
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", gap:10 }}>
        <span>🔔 {msg}</span>
        <button onClick={onClose} style={{ background:"none", border:"none", color:"#c9a84c", cursor:"pointer", fontSize:18 }}>✕</button>
      </div>
    </div>
  );
}

// ==================== ATTENDANCE MODULE ====================
function AttendanceModule({ students, grade, onBack }) {
  const [list, setList] = useState(students);
  const [absences, setAbsences] = useState({});
  const [newName, setNewName] = useState("");
  const [sessionDate, setSessionDate] = useState(getNow());
  const [notify, setNotify] = useState(null);

  const toggle = (id) => {
    const updated = { ...absences };
    if (!updated[id]) updated[id] = [];
    const today = sessionDate;
    if (updated[id].includes(today)) {
      updated[id] = updated[id].filter(d => d !== today);
    } else {
      updated[id].push(today);
      const st = list.find(s => s.id === id);
      setNotify(`تم إرسال إشعار غياب لولي أمر ${st?.name} على الواتساب والـ SMS`);
    }
    setAbsences(updated);
  };

  const addStudent = () => {
    if (!newName.trim()) return;
    const ns = { id: Date.now(), name: newName.trim(), parentName: "—", parentPhone: "—" };
    setList([...list, ns]);
    setNewName("");
  };

  const remove = (id) => setList(list.filter(s => s.id !== id));
  const isAbsent = (id) => absences[id]?.includes(sessionDate);

  return (
    <div style={moduleWrap}>
      {notify && <NotificationToast msg={notify} onClose={() => setNotify(null)} />}
      <div style={moduleHeader}>
        <button onClick={onBack} style={backBtn}>← رجوع</button>
        <h2 style={moduleTitle}>📋 تسجيل الغياب — {gradeNames[grade]}</h2>
      </div>

      <div style={{ display:"flex", gap:12, marginBottom:20, alignItems:"center", flexWrap:"wrap" }}>
        <div style={infoCard}>
          <Icon name="calendar" size={16} /> الجلسة: <strong>{sessionDate}</strong>
        </div>
        <div style={infoCard}>
          غائبون: <strong style={{ color:"#e74c3c" }}>{Object.values(absences).filter(a => a.includes(sessionDate)).length}</strong> / {list.length}
        </div>
      </div>

      <div style={{ display:"flex", gap:10, marginBottom:20 }}>
        <input value={newName} onChange={e => setNewName(e.target.value)}
          placeholder="اسم الطالب الجديد..." style={inputStyle} onKeyDown={e => e.key==="Enter" && addStudent()} />
        <button onClick={addStudent} style={addBtn}>+ إضافة</button>
      </div>

      <div style={tableWrap}>
        <table style={tableStyle}>
          <thead>
            <tr>
              <th style={th}>#</th>
              <th style={th}>اسم الطالب</th>
              <th style={th}>الغياب اليوم</th>
              <th style={th}>إجمالي الغياب</th>
              <th style={th}>حذف</th>
            </tr>
          </thead>
          <tbody>
            {list.map((s, i) => (
              <tr key={s.id} style={{ background: isAbsent(s.id) ? "rgba(231,76,60,0.12)" : "transparent" }}>
                <td style={td}>{i + 1}</td>
                <td style={{ ...td, fontWeight: 600 }}>{s.name}</td>
                <td style={td}>
                  <button onClick={() => toggle(s.id)} style={{
                    ...toggleBtn,
                    background: isAbsent(s.id) ? "#e74c3c" : "#27ae60",
                    transform: isAbsent(s.id) ? "scale(1.05)" : "scale(1)"
                  }}>
                    {isAbsent(s.id) ? "❌ غائب" : "✅ حاضر"}
                  </button>
                </td>
                <td style={{ ...td, color: "#c9a84c" }}>
                  {absences[s.id]?.length || 0} حصة
                </td>
                <td style={td}>
                  <button onClick={() => remove(s.id)} style={deleteBtn}>🗑</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {Object.values(absences).some(a => a.length > 0) && (
        <div style={{ marginTop:24, padding:16, background:"rgba(201,168,76,0.1)", border:"1px solid #c9a84c", borderRadius:10 }}>
          <h3 style={{ color:"#c9a84c", margin:"0 0 10px", fontSize:14 }}>📊 سجل الغياب الكامل</h3>
          {list.filter(s => absences[s.id]?.length).map(s => (
            <div key={s.id} style={{ marginBottom:6, fontSize:13, color:"#ddd" }}>
              <strong>{s.name}</strong>: غاب {absences[s.id].length} مرة
              <span style={{ color:"#e74c3c", fontSize:11, marginRight:8 }}>({absences[s.id].join(" | ")})</span>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ==================== FEES MODULE ====================
function FeesModule({ students, grade, onBack }) {
  const [fees, setFees] = useState({});
  const [notify, setNotify] = useState(null);
  const months = monthNames;

  const toggleMonth = (id, month) => {
    const updated = { ...fees };
    if (!updated[id]) updated[id] = {};
    if (updated[id][month]) {
      delete updated[id][month];
    } else {
      updated[id][month] = getNow();
      const st = students.find(s => s.id === id);
      setNotify(`تم إشعار ولي أمر ${st?.name} بتأكيد دفع شهر ${month}`);
    }
    setFees(updated);
  };

  const currentMonth = monthNames[new Date().getMonth()];
  const unpaid = students.filter(s => !fees[s.id]?.[currentMonth]);

  return (
    <div style={moduleWrap}>
      {notify && <NotificationToast msg={notify} onClose={() => setNotify(null)} />}
      <div style={moduleHeader}>
        <button onClick={onBack} style={backBtn}>← رجوع</button>
        <h2 style={moduleTitle}>💰 المصاريف — {gradeNames[grade]}</h2>
      </div>

      <div style={{ display:"flex", gap:12, marginBottom:20, flexWrap:"wrap" }}>
        <div style={infoCard}>لم يدفعوا هذا الشهر: <strong style={{ color:"#e74c3c" }}>{unpaid.length}</strong></div>
        <div style={infoCard}>دفعوا: <strong style={{ color:"#27ae60" }}>{students.length - unpaid.length}</strong></div>
      </div>

      <div style={{ overflowX:"auto" }}>
        <table style={tableStyle}>
          <thead>
            <tr>
              <th style={th}>الطالب</th>
              {months.slice(0,6).map(m => <th key={m} style={{ ...th, fontSize:11 }}>{m}</th>)}
              {months.slice(6).map(m => <th key={m} style={{ ...th, fontSize:11 }}>{m}</th>)}
            </tr>
          </thead>
          <tbody>
            {students.map(s => (
              <tr key={s.id}>
                <td style={{ ...td, fontWeight:600, whiteSpace:"nowrap" }}>{s.name}</td>
                {months.map(m => (
                  <td key={m} style={td}>
                    <button onClick={() => toggleMonth(s.id, m)} title={fees[s.id]?.[m] || ""} style={{
                      width:36, height:36, borderRadius:8, border:"none", cursor:"pointer", fontSize:16,
                      background: fees[s.id]?.[m] ? "rgba(39,174,96,0.2)" : "rgba(255,255,255,0.05)",
                      transition:"all 0.2s"
                    }}>
                      {fees[s.id]?.[m] ? "✅" : "⬜"}
                    </button>
                    {fees[s.id]?.[m] && (
                      <div style={{ fontSize:9, color:"#aaa", marginTop:2, textAlign:"center" }}>
                        {fees[s.id][m].split(" ")[0]}
                      </div>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

// ==================== FILES MODULE ====================
function FilesModule({ grade, onBack }) {
  const [files, setFiles] = useState([
    { id: 1, name: "شرح الباب الأول - المشتقات.pdf", date: "الأحد 28/4/2024", size: "2.3 MB", sent: true },
    { id: 2, name: "تمارين الفصل الثاني.pdf", date: "الثلاثاء 30/4/2024", size: "1.1 MB", sent: false },
  ]);
  const [notify, setNotify] = useState(null);

  const upload = () => {
    const name = prompt("اسم الملف (للمحاكاة):");
    if (!name) return;
    setFiles([...files, { id: Date.now(), name, date: getNow(), size: "1.5 MB", sent: false }]);
  };

  const sendToStudents = (id) => {
    setFiles(files.map(f => f.id === id ? { ...f, sent: true } : f));
    setNotify("تم إرسال الملف لجميع طلاب المجموعة بنجاح! 📤");
  };

  const remove = (id) => setFiles(files.filter(f => f.id !== id));

  return (
    <div style={moduleWrap}>
      {notify && <NotificationToast msg={notify} onClose={() => setNotify(null)} />}
      <div style={moduleHeader}>
        <button onClick={onBack} style={backBtn}>← رجوع</button>
        <h2 style={moduleTitle}>📁 ملفات الحصص — {gradeNames[grade]}</h2>
      </div>

      <button onClick={upload} style={{ ...addBtn, marginBottom:20, padding:"12px 24px" }}>
        ⬆ رفع ملف جديد
